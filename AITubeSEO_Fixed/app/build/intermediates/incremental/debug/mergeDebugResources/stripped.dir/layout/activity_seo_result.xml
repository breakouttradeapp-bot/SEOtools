<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Topic chip -->
            <TextView
                android:id="@+id/tvTopic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="📌 Topic"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:background="@drawable/card_border" />

            <!-- Title Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:alpha="0"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🎯 VIDEO TITLE"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:letterSpacing="0.1" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:text="Copy"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            app:cornerRadius="8dp"
                            android:backgroundTint="@color/primary_ultra_light"
                            android:textColor="@color/primary"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Description Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:alpha="0"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📝 DESCRIPTION"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:letterSpacing="0.1" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:text="Copy"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            app:cornerRadius="8dp"
                            android:backgroundTint="@color/primary_ultra_light"
                            android:textColor="@color/primary"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tags Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:alpha="0"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🏷️ TAGS (20)"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:letterSpacing="0.1" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyTags"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:text="Copy"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            app:cornerRadius="8dp"
                            android:backgroundTint="@color/primary_ultra_light"
                            android:textColor="@color/primary"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvTags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hashtags Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHashtags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="#️⃣ HASHTAGS (15)"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:letterSpacing="0.1" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyHashtags"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:text="Copy"
                            android:textSize="11sp"
                            android:paddingHorizontal="12dp"
                            app:cornerRadius="8dp"
                            android:backgroundTint="@color/primary_ultra_light"
                            android:textColor="@color/primary"
                            app:strokeColor="@color/primary"
                            app:strokeWidth="1dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvHashtags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="13sp"
                        android:textColor="@color/primary"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Share All Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareAll"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📤 Share All Content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/primary"
                app:cornerRadius="14dp"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- Banner Ad -->
                        <FrameLayout
                android:id="@+id/bannerAdContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
