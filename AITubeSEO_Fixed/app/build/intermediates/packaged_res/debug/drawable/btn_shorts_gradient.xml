<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#7B0000" android:endColor="#B71C1C" android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#C62828" android:endColor="#FF1744" android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
