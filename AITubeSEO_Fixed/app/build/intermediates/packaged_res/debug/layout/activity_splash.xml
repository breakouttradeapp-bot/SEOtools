<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient">

    <!-- Top-right decorative circle -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-70dp"
        android:layout_marginEnd="-70dp"
        android:background="@drawable/circle_pulse"
        android:alpha="0.18" />

    <!-- Bottom-left decorative circle -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-50dp"
        android:layout_marginStart="-50dp"
        android:background="@drawable/circle_pulse"
        android:alpha="0.14" />

    <!-- ── CENTER BLOCK ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="36dp">

        <!-- App icon / logo -->
        <ImageView
            android:id="@+id/lottieAnim"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/ic_launcher_fg"
            android:alpha="0"
            android:scaleX="0.5"
            android:scaleY="0.5"
            android:contentDescription="App Logo" />

        <!-- App name — solid white, large, bold -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="AI Tube SEO"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:shadowColor="#88000000"
            android:shadowDx="1"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:alpha="0" />

        <!-- Tagline — white with subtle shadow -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="AI-Powered YouTube SEO Generator"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:shadowColor="#88000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:alpha="0" />

        <!-- Divider line -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginTop="20dp"
            android:background="#66FFFFFF"
            android:alpha="0" />

        <!-- Feature pills row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tags"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:background="#44FFFFFF"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titles"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:background="#44FFFFFF"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hashtags"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:background="#44FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── BOTTOM BLOCK ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="48dp">

        <!-- "Powered by" text — clearly visible white -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by Cerebras AI"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:alpha="0" />

        <!-- Loading spinner — white tint on dark background = clearly visible -->
        <ProgressBar
            android:id="@+id/loadingDots"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="14dp"
            android:indeterminateTint="#FFFFFF"
            style="?android:attr/progressBarStyle" />
    </LinearLayout>

</FrameLayout>
