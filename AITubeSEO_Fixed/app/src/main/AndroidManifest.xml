<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AITubeSEO"
        android:networkSecurityConfig="@xml/network_security_config"
        android:hardwareAccelerated="true">

        <!--
        ════════════════════════════════════════════════════════
        ⚠️  ADMOB APP ID — REPLACE WITH YOUR REAL APP ID
        ════════════════════════════════════════════════════════
        Format: ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
        Test ID (for development): ca-app-pub-3940256099942544~3347511713

        IMPORTANT: Using a wrong App ID here WILL crash the app.
        Get your real App ID from: https://apps.admob.com
        ════════════════════════════════════════════════════════
        -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/admob_app_id" />

        <!-- Delay AdMob auto-init to prevent startup crash -->
        <meta-data
            android:name="com.google.android.gms.ads.DELAY_APP_MEASUREMENT_INIT"
            android:value="true" />

        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AITubeSEO.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".activities.SeoResultActivity"
            android:exported="false" />

        <activity
            android:name=".activities.ShortsResultActivity"
            android:exported="false" />

        <activity
            android:name=".activities.HistoryActivity"
            android:exported="false" />

        <activity
            android:name=".activities.PrivacyPolicyActivity"
            android:exported="false" />

    </application>

</manifest>
